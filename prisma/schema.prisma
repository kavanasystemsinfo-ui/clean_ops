// =============================================================================
// Kavana CleanOps — Prisma Schema v1.0.0
// Provider: PostgreSQL 16
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Model: Usuario
// Descripción: Usuarios del sistema con roles y estado laboral
// =============================================================================
model Usuario {
  id_usuario    Int       @id @default(autoincrement())
  nombre        String    @db.VarChar(100)
  email         String    @unique @db.VarChar(100)
  password_hash String    @db.VarChar(255)
  rol           String    @default("limpiador") @db.VarChar(20) // limpiador | supervisor | admin
  estado        String    @default("activo") @db.VarChar(20)    // activo | baja_medica | inactivo

  asignaciones       AsignacionPersonal[]
  registroMovimientos RegistroMovimiento[]

  tokensExpirados    RefreshToken[]

  @@map("usuarios")
}

// =============================================================================
// Model: Centro
// Descripción: Centros de trabajo (colegios, oficinas, fábricas, etc.)
// =============================================================================
model Centro {
  id_centro     Int       @id @default(autoincrement())
  nombre_centro String    @db.VarChar(150)
  direccion     String?   @db.VarChar(255)

  asignaciones       AsignacionPersonal[]
  inventarioCentros  InventarioCentro[]
  registroMovimientos RegistroMovimiento[]

  @@map("centros")
}

// =============================================================================
// Model: Producto
// Descripción: Catálogo global de productos consumibles
// =============================================================================
model Producto {
  id_producto       Int     @id @default(autoincrement())
  nombre_producto   String  @db.VarChar(100)
  unidad_medida     String  @default("unidades") @db.VarChar(20)
  stock_minimo_alerta Int   @default(5)

  inventarioCentros  InventarioCentro[]
  registroMovimientos RegistroMovimiento[]

  @@map("productos")
}

// =============================================================================
// Model: AsignacionPersonal
// Descripción: Asignaciones temporales de personal a centros de trabajo.
//   fecha_fin = NULL significa personal fijo (indefinido).
//   Query crítica: SELECT id_centro WHERE id_usuario = ? 
//     AND fecha_inicio <= CURRENT_DATE 
//     AND (fecha_fin >= CURRENT_DATE OR fecha_fin IS NULL);
// =============================================================================
model AsignacionPersonal {
  id_asignacion Int   @id @default(autoincrement())
  id_usuario    Int
  id_centro     Int
  fecha_inicio  DateTime @db.Date
  fecha_fin     DateTime? @db.Date

  usuario Usuario @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  centro  Centro  @relation(fields: [id_centro], references: [id_centro], onDelete: Cascade)

  @@index([id_usuario, fecha_inicio, fecha_fin], name: "idx_asignaciones_usuario_fecha")
  @@map("asignaciones_personal")
}

// =============================================================================
// Model: InventarioCentro
// Descripción: Stock actual de cada producto en cada centro.
//   PK compuesta (id_centro, id_producto) garantiza 1 fila por producto/centro.
// =============================================================================
model InventarioCentro {
  id_centro      Int
  id_producto    Int
  cantidad_actual Int @default(0)

  centro  Centro  @relation(fields: [id_centro], references: [id_centro])
  producto Producto @relation(fields: [id_producto], references: [id_producto])

  @@id([id_centro, id_producto])
  @@map("inventario_centros")
}

// =============================================================================
// Model: RefreshToken
// Descripción: Tokens de actualización JWT para sesiones persistentes
// =============================================================================
model RefreshToken {
  id_refresh_token Int      @id @default(autoincrement())
  id_usuario       Int
  token            String   @unique @db.VarChar(512)
  expires_at       DateTime
  created_at       DateTime @default(now())
  revoked          Boolean  @default(false)

  usuario Usuario @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@index([id_usuario], name: "idx_refresh_usuario")
  @@map("refresh_tokens")
}

// =============================================================================
// Model: RegistroMovimiento
// Descripción: Auditoría de todos los movimientos de stock.
//   cantidad < 0 = Consumo (salida)
//   cantidad > 0 = Reposición (entrada)
// =============================================================================
model RegistroMovimiento {
  id_movimiento Int      @id @default(autoincrement())
  id_usuario    Int
  id_centro     Int
  id_producto   Int
  cantidad      Int      // Negativo = salida, Positivo = entrada
  fecha_hora    DateTime @default(now()) @db.Timestamp(6)

  usuario  Usuario  @relation(fields: [id_usuario], references: [id_usuario])
  centro   Centro   @relation(fields: [id_centro], references: [id_centro])
  producto Producto @relation(fields: [id_producto], references: [id_producto])

  @@index([id_centro, fecha_hora], name: "idx_movimientos_centro_fecha")
  @@map("registro_movimientos")
}
