# Kavana CleanOps — Environment Variables
# Copy this file to .env and customize for your environment.

# Database (for local development outside Docker)
# Inside Docker, DATABASE_URL is auto-built from DB_PASSWORD in docker-compose.yml
DATABASE_URL="postgresql://kavana:change_me_to_a_strong_password@localhost:5432/kavana_cleanops"

# JWT
JWT_SECRET=change_me_to_a_strong_random_secret
JWT_EXPIRES_IN=15m

# Refresh Tokens
REFRESH_TOKEN_EXPIRY_DAYS=30

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*
